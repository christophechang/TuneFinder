# Discord bot
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Volumo API
VOLUMO_API_KEY=

# Beatport login
BEATPORT_USERNAME=       # Beatport login — required to enable the Beatport source (unofficial API, personal use)
BEATPORT_PASSWORD=

# SoundCloud official API app (client_credentials — no callback URL involved).
# Registering an app requires a SoundCloud Artist Pro subscription.
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=

# --- Web service (tunefinder serve) ---
# Bearer secret required on every API call (any long random string).
# The SPA stores it in Settings. Required unless TUNEFINDER_WEB_INSECURE=1.
TUNEFINDER_API_SECRET=

# Explicit auth opt-out for trusted-network (LAN/Tailscale) deployments.
# TUNEFINDER_WEB_INSECURE=1

# CORS origins for a separately-hosted SPA (comma-separated).
# Not needed for the static mount or a same-origin reverse proxy.
# TUNEFINDER_WEB_ALLOWED_ORIGINS=https://tunefinder.example.com

# Public URL of the web app — Discord reports link to it when set
# (supersedes the audition-page link).
# TUNEFINDER_WEB_BASE_URL=https://tunefinder.example.com

# Serve a built tunefinder-web bundle from this directory (zero-CORS LAN mode).
# TUNEFINDER_WEB_STATIC_DIR=/path/to/tunefinder-web/dist

# Legacy audition page hosting (fallback report link when web_base_url unset)
# TUNEFINDER_AUDITION_BASE_URL=
